# --------------------------------------------------
# Django core
# --------------------------------------------------

SECRET_KEY=replace-with-a-long-random-secret-key
DEBUG=True

# Comma-separated hosts without http/https
ALLOWED_HOSTS=127.0.0.1,localhost


# --------------------------------------------------
# React frontend / CORS
# --------------------------------------------------

# Comma-separated full frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Required when Django admin or cookie-based requests
# are sent from another trusted origin.
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173


# --------------------------------------------------
# Database
# --------------------------------------------------

# Development:
DB_ENGINE=sqlite

# Production PostgreSQL:
# DB_ENGINE=postgresql
# DB_NAME=trading_platform
# DB_USER=trading_user
# DB_PASSWORD=replace-with-secure-password
# DB_HOST=127.0.0.1
# DB_PORT=5432


# --------------------------------------------------
# HTTPS security
# --------------------------------------------------

SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Production examples:
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True